{#
/**
 * @file
 * Hous-Z management dashboard.
 *
 * Available variables:
 * - stats:       Array with keys: rooms, total, pending, confirmed, cancelled, today.
 * - upcoming:    Array of upcoming check-in rows (next 7 days).
 * - recent:      Array of recent booking rows.
 * - username:    Current user display name.
 * - greeting:    "morning", "afternoon", or "evening".
 * - today_label: Formatted date string e.g. "Sunday, 06 April 2025".
 */
#}

<div class="hz-dash">

  {# ── Welcome bar ── #}
  <div class="hz-dash__welcome">
    <div>
      <h1 class="hz-dash__title">Good {{ greeting }}, {{ username }}</h1>
      <p class="hz-dash__subtitle">{{ today_label }} &bull; Room Booking Overview</p>
    </div>
    <div class="hz-dash__welcome-actions">
      <a href="/housz/bookings" class="button button--primary">View all bookings</a>
      <a href="/housz/units" class="button button--secondary">Manage rooms</a>
    </div>
  </div>

  {# ── Stat cards ── #}
  <div class="hz-stats">

    <div class="hz-stat hz-stat--purple">
      <div class="hz-stat__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19 2H5a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2zm-9 3h8v2h-8V5zm-4 0h2v2H6V5zm13 14H5v-2h14v2zm0-4H5v-6h14v6z"/>
        </svg>
      </div>
      <div class="hz-stat__body">
        <span class="hz-stat__value">{{ stats.rooms }}</span>
        <span class="hz-stat__label">Total Rooms</span>
      </div>
    </div>

    <div class="hz-stat hz-stat--dark">
      <div class="hz-stat__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z"/>
        </svg>
      </div>
      <div class="hz-stat__body">
        <span class="hz-stat__value">{{ stats.total }}</span>
        <span class="hz-stat__label">Total Bookings</span>
      </div>
    </div>

    <div class="hz-stat hz-stat--warning">
      <div class="hz-stat__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
        </svg>
      </div>
      <div class="hz-stat__body">
        <span class="hz-stat__value">{{ stats.pending }}</span>
        <span class="hz-stat__label">Pending Review</span>
      </div>
      {% if stats.pending > 0 %}
        <a href="/housz/bookings" class="hz-stat__cta">Review →</a>
      {% endif %}
    </div>

    <div class="hz-stat hz-stat--success">
      <div class="hz-stat__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
        </svg>
      </div>
      <div class="hz-stat__body">
        <span class="hz-stat__value">{{ stats.confirmed }}</span>
        <span class="hz-stat__label">Confirmed</span>
      </div>
    </div>

    <div class="hz-stat hz-stat--accent">
      <div class="hz-stat__icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm4.24 16L12 15.45 7.77 18l1.12-4.81-3.73-3.23 4.92-.42L12 5l1.92 4.53 4.92.42-3.73 3.23L16.23 18z"/>
        </svg>
      </div>
      <div class="hz-stat__body">
        <span class="hz-stat__value">{{ stats.today }}</span>
        <span class="hz-stat__label">Check-ins Today</span>
      </div>
    </div>

  </div>

  {# ── Main content grid ── #}
  <div class="hz-dash__grid">

    {# Upcoming check-ins #}
    <div class="hz-panel hz-panel--wide">
      <div class="hz-panel__header">
        <h2 class="hz-panel__title">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg>
          Upcoming Check-ins
          <span class="hz-panel__badge">Next 7 days</span>
        </h2>
        <a href="/housz/bookings" class="hz-panel__link">View all →</a>
      </div>

      {% if upcoming is empty %}
        <div class="hz-empty">
          <p>No upcoming check-ins in the next 7 days.</p>
        </div>
      {% else %}
        <div class="hz-table-wrap">
          <table class="hz-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Room</th>
                <th>Guest</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              {% for row in upcoming %}
                <tr>
                  <td class="hz-table__id">#{{ row.id }}</td>
                  <td><strong>{{ row.room }}</strong></td>
                  <td class="hz-table__email">{{ row.guest }}</td>
                  <td>{{ row.check_in }}</td>
                  <td>{{ row.check_out }}</td>
                  <td>
                    <span class="hz-badge hz-badge--{{ row.status }}">{{ row.status_label }}</span>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endif %}
    </div>

    {# Recent bookings #}
    <div class="hz-panel">
      <div class="hz-panel__header">
        <h2 class="hz-panel__title">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42A8.954 8.954 0 0 0 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"/></svg>
          Recent Bookings
        </h2>
        <a href="/housz/bookings" class="hz-panel__link">View all →</a>
      </div>

      {% if recent is empty %}
        <div class="hz-empty">
          <p>No bookings yet.</p>
        </div>
      {% else %}
        <div class="hz-table-wrap">
          <table class="hz-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Room</th>
                <th>Guest</th>
                <th>Dates</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              {% for row in recent %}
                <tr>
                  <td class="hz-table__id">#{{ row.id }}</td>
                  <td><strong>{{ row.room }}</strong></td>
                  <td class="hz-table__email">{{ row.guest }}</td>
                  <td class="hz-table__dates">{{ row.check_in }}<br><small>→ {{ row.check_out }}</small></td>
                  <td>
                    <span class="hz-badge hz-badge--{{ row.status }}">{{ row.status_label }}</span>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endif %}
    </div>

  </div>{# /.hz-dash__grid #}

</div>{# /.hz-dash #}
