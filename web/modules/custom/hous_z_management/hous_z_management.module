<?php

/**
 * @file
 * Housz Management module file.
 */

/**
 * Implements hook_mail().
 *
 * Sends notifications related to bookings and reservations.
 *
 * @param string $key
 *   The e-mail key.
 * @param array  $message
 *   The message array.
 * @param array  $params
 *   Parameters passed to the mail, including 'summary'.
 */
function hous_z_management_mail($key, &$message, $params) {
  switch ($key) {
    case 'booking_notification':
      // Extract the booking summary.
      /** @var array $summary */
      $summary = $params['summary'];

      // Build the e-mail subject.
      $message['subject'] = t('New reservation: @room', [
        '@room' => $summary['room']['roomName'],
      ]);

      // Ensure address and managerEmail are always strings.
      $address      = !empty($summary['room']['address'])      ? $summary['room']['address']      : '';
      $managerEmail = !empty($summary['room']['managerEmail']) ? $summary['room']['managerEmail'] : '';

      // Build the e-mail body (plain text).
      $body = [];
      $body[] = t('A new reservation has been made for room: @room.', [
        '@room' => $summary['room']['roomName'],
      ]);
      $body[] = '';
      $body[] = t('Check-in: @date @time', [
        '@date' => $summary['bookingInfo']['checkIn']['date'],
        '@time' => $summary['bookingInfo']['checkIn']['time'],
      ]);
      $body[] = t('Check-out: @date @time', [
        '@date' => $summary['bookingInfo']['checkOut']['date'],
        '@time' => $summary['bookingInfo']['checkOut']['time'],
      ]);
      $body[] = '';
      $body[] = t('Details:');
      $body[] = $summary['details'] ?: t('No additional details provided.');
      $body[] = '';
      $body[] = t('Address: @address', ['@address' => $address]);
      $body[] = '';
      $body[] = t('Manager email: @email', ['@email' => $managerEmail]);

      $message['body'] = $body;
      break;

    case 'booking_confirmed':
      $booking = $params['booking'];
      $message['subject'] = t('Booking Confirmed: @label', [
        '@label' => $booking->label(),
      ]);
      
      $body = [];
      $body[] = t('Your booking has been confirmed.');
      $body[] = t('Booking ID: @id', ['@id' => $booking->id()]);
      $body[] = t('Details: @label', ['@label' => $booking->label()]);
      $body[] = '';
      $body[] = t('Thank you for choosing our services.');
      
      $message['body'] = $body;
      break;

    case 'booking_cancelled':
      $booking = $params['booking'];
      $message['subject'] = t('Booking Cancelled: @label', [
        '@label' => $booking->label(),
      ]);
      
      $body = [];
      $body[] = t('Your booking has been cancelled.');
      $body[] = t('Booking ID: @id', ['@id' => $booking->id()]);
      $body[] = t('Details: @label', ['@label' => $booking->label()]);
      $body[] = '';
      $body[] = t('If you have any questions, please contact us.');
      
      $message['body'] = $body;
      break;
  }
}

/**
 * Implements hook_user_login().
 *
 * Redirects users to the dashboard after login.
 */
function hous_z_management_user_login($account) {
  // Only redirect if there's no existing destination parameter.
  $request = \Drupal::request();
  if (!$request->query->has('destination')) {
    // Set the destination to the Houz dashboard.
    $request->query->set('destination', '/admin/houz');
  }
}