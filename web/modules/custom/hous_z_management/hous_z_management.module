<?php

/**
 * @file
 * Housz Management module file.
 */

/**
 * Implements hook_theme().
 */
function hous_z_management_theme(): array {
  return [
    'hous_z_dashboard' => [
      'variables' => [
        'stats'       => [],
        'upcoming'    => [],
        'recent'      => [],
        'username'    => '',
        'greeting'    => '',
        'today_label' => '',
      ],
    ],
    'hous_z_landing' => [
      'variables' => [],
    ],
    'hous_z_bookings' => [
      'variables' => [
        'rows'         => [],
        'total'        => 0,
        'state_filter' => '',
        'pager'        => [],
      ],
    ],
    'hous_z_units' => [
      'variables' => [
        'rows'    => [],
        'add_url' => '',
      ],
    ],
  ];
}

/**
 * Implements hook_preprocess_hous_z_landing().
 */
function hous_z_management_preprocess_hous_z_landing(array &$variables): void {
  $variables['#attached']['library'][] = 'hous_z_management/landing';
}

/**
 * Implements hook_entity_type_alter().
 *
 * Override BAT Event entity to use custom class with label functionality.
 */
function hous_z_management_entity_type_alter(array &$entity_types) {
  /** @var \Drupal\Core\Entity\EntityTypeInterface[] $entity_types */
  if (isset($entity_types['bat_event'])) {
    $entity_types['bat_event']->setClass('Drupal\hous_z_management\Entity\HouzEvent');
  }
}

/**
 * Implements hook_user_login().
 *
 * Redirects users to the dashboard after login.
 */
function hous_z_management_user_login($account) {
  $request = \Drupal::request();
  if (!$request->query->has('destination')) {
    $request->query->set('destination', '/housz');
  }
}

/**
 * Implements hook_form_alter().
 *
 * After password reset, redirect to /user/login so the status message
 * is visible instead of being swallowed by the anonymous landing page.
 */
function hous_z_management_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  if ($form_id === 'user_pass') {
    $form['#submit'][] = 'hous_z_management_user_pass_submit';
  }
}

/**
 * Custom submit handler for the password reset form.
 */
function hous_z_management_user_pass_submit($form, \Drupal\Core\Form\FormStateInterface $form_state) {
  $form_state->setRedirect('user.login');
}
