<?php

use Drupal\Core\Entity\EntityInterface;

/**
 * Implements hook_theme().
 */
function hous_z_api_theme(): array {
  return [
    'hous_z_api_email' => [
      'template'  => 'email/hous-z-api-email',
      'variables' => [
        'heading'      => '',
        'intro'        => '',
        'rows'         => [],
        'details'      => '',
        'status'       => 'pending',
        'status_label' => '',
        'cta_email'    => '',
        'logo_url'     => '',
      ],
    ],
  ];
}

/**
 * Implements hook_entity_insert().
 */
function hous_z_api_entity_insert(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'bat_booking' || $entity->bundle() !== 'standard') {
    return;
  }

  \Drupal::service('hous_z_api.booking_notifier')->notifyBookingCreated($entity);
}

/**
 * Implements hook_entity_update().
 */
function hous_z_api_entity_update(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'bat_booking' || $entity->bundle() !== 'standard') {
    return;
  }

  $original = $entity->original ?? NULL;
  if (!$original) {
    return;
  }

  $old_state = (int) $original->get('field_event_state')->target_id;
  $new_state = (int) $entity->get('field_event_state')->target_id;
  if ($old_state === $new_state) {
    return;
  }

  \Drupal::service('hous_z_api.booking_notifier')->notifyBookingUpdated($entity, $original);
}
