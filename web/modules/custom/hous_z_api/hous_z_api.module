<?php

use Drupal\Component\Utility\Html;
use Drupal\Core\Entity\EntityInterface;

/**
 * Builds the full branded HTML for a given email key and context.
 *
 * Called by BookingNotifier::send() — keeps rendering logic in .module so
 * it stays co-located with the email keys it serves.
 */
function hous_z_api_build_email_html(string $key, array $context): string {
  $room_name     = Html::escape((string) ($context['roomName'] ?? 'Room'));
  $booking_id    = Html::escape((string) ($context['bookingId'] ?? ''));
  $status_label  = Html::escape((string) ($context['statusLabel'] ?? ucfirst((string) ($context['status'] ?? ''))));
  $status_machine = Html::escape((string) ($context['status'] ?? 'pending'));
  $prev_status   = Html::escape((string) ($context['previousStatusLabel'] ?? ucfirst((string) ($context['previousStatus'] ?? ''))));
  $address       = Html::escape((string) ($context['address'] ?? ''));
  $check_in      = Html::escape(trim((string) (($context['checkInDate'] ?? '') . ' ' . ($context['checkInTime'] ?? ''))));
  $check_out     = Html::escape(trim((string) (($context['checkOutDate'] ?? '') . ' ' . ($context['checkOutTime'] ?? ''))));
  $guest_email   = Html::escape((string) ($context['requesterEmail'] ?? ''));
  $manager_email = Html::escape((string) ($context['managerEmail'] ?? ''));
  $details       = nl2br(Html::escape(trim((string) ($context['details'] ?? ''))));

  return match($key) {
    'booking_created_admin' => hous_z_api_render_email(
      heading: 'New booking request',
      intro: 'A new booking is pending your review.',
      rows: array_filter([
        ['Booking ID', "#{$booking_id}"],
        ['Guest', $guest_email],
        ['Room', $room_name],
        ['Check-in', $check_in],
        ['Check-out', $check_out],
        $address !== '' ? ['Address', $address] : [],
      ], fn($r) => !empty($r)),
      details: $details,
      status: 'pending',
      status_label: 'Pending',
    ),
    'booking_created_guest' => hous_z_api_render_email(
      heading: 'Booking request received',
      intro: 'Your booking request was received. You will be notified once it is reviewed.',
      rows: array_filter([
        ['Booking ID', "#{$booking_id}"],
        ['Room', $room_name],
        ['Check-in', $check_in],
        ['Check-out', $check_out],
        ['Status', 'Pending review'],
        $address !== '' ? ['Address', $address] : [],
      ], fn($r) => !empty($r)),
      details: $details,
      status: 'pending',
      status_label: 'Pending',
      cta_email: $manager_email,
    ),
    'booking_confirmed' => hous_z_api_render_email(
      heading: 'Your booking is confirmed',
      intro: 'Great news — your booking has been approved.',
      rows: array_filter([
        ['Booking ID', "#{$booking_id}"],
        ['Room', $room_name],
        ['Check-in', $check_in],
        ['Check-out', $check_out],
        ['Status', 'Confirmed'],
        $address !== '' ? ['Address', $address] : [],
      ], fn($r) => !empty($r)),
      status: 'confirmed',
      status_label: 'Confirmed',
      cta_email: $manager_email,
    ),
    'booking_cancelled' => hous_z_api_render_email(
      heading: 'Your booking has been cancelled',
      intro: 'Unfortunately your booking has been cancelled.',
      rows: array_filter([
        ['Booking ID', "#{$booking_id}"],
        ['Room', $room_name],
        ['Check-in', $check_in],
        ['Check-out', $check_out],
        ['Status', 'Cancelled'],
      ], fn($r) => !empty($r)),
      details: $details,
      status: 'cancelled',
      status_label: 'Cancelled',
      cta_email: $manager_email,
    ),
    'booking_status_admin' => hous_z_api_render_email(
      heading: "Booking #{$booking_id} status updated",
      intro: 'A booking status has changed.',
      rows: array_filter([
        ['Booking ID', "#{$booking_id}"],
        ['Room', $room_name],
        ['Guest', $guest_email],
        ['Check-in', $check_in],
        ['Check-out', $check_out],
        ['New status', $status_label],
        $prev_status !== '' ? ['Previous', $prev_status] : [],
      ], fn($r) => !empty($r)),
      details: $details,
      status: $status_machine,
      status_label: $status_label,
    ),
    'booking_status_changed' => hous_z_api_render_email(
      heading: 'Your booking was updated',
      intro: 'Your booking status has changed.',
      rows: array_filter([
        ['Booking ID', "#{$booking_id}"],
        ['Room', $room_name],
        ['Check-in', $check_in],
        ['Check-out', $check_out],
        ['New status', $status_label],
        $prev_status !== '' ? ['Previous', $prev_status] : [],
      ], fn($r) => !empty($r)),
      status: $status_machine,
      status_label: $status_label,
      cta_email: $manager_email,
    ),
    default => '',
  };
}

/**
 * Implements hook_entity_insert().
 */
function hous_z_api_entity_insert(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'bat_booking' || $entity->bundle() !== 'standard') {
    return;
  }

  \Drupal::service('hous_z_api.booking_notifier')->notifyBookingCreated($entity);
}

/**
 * Implements hook_entity_update().
 */
function hous_z_api_entity_update(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'bat_booking' || $entity->bundle() !== 'standard') {
    return;
  }

  $original = $entity->original ?? NULL;
  if (!$original) {
    return;
  }

  $old_state = (int) $original->get('field_event_state')->target_id;
  $new_state = (int) $entity->get('field_event_state')->target_id;
  if ($old_state === $new_state) {
    return;
  }

  \Drupal::service('hous_z_api.booking_notifier')->notifyBookingUpdated($entity, $original);
}

/**
 * Implements hook_mail().
 *
 * Kept as a no-op stub — emails are now sent via Symfony Mailer EmailFactory
 * in BookingNotifier. This hook is no longer invoked for hous_z_api emails.
 */
function hous_z_api_mail(string $key, array &$message, array $params): void {
  $context = $params['context'] ?? [];

  $room_name      = Html::escape((string) ($context['roomName'] ?? 'Room'));
  $booking_id     = Html::escape((string) ($context['bookingId'] ?? ''));
  $status_label   = Html::escape((string) ($context['statusLabel'] ?? ucfirst((string) ($context['status'] ?? ''))));
  $status_machine = Html::escape((string) ($context['status'] ?? 'pending'));
  $prev_status    = Html::escape((string) ($context['previousStatusLabel'] ?? ucfirst((string) ($context['previousStatus'] ?? ''))));
  $address        = Html::escape((string) ($context['address'] ?? ''));
  $check_in       = Html::escape(trim((string) (($context['checkInDate'] ?? '') . ' ' . ($context['checkInTime'] ?? ''))));
  $check_out      = Html::escape(trim((string) (($context['checkOutDate'] ?? '') . ' ' . ($context['checkOutTime'] ?? ''))));
  $guest_email    = Html::escape((string) ($context['requesterEmail'] ?? ''));
  $manager_email  = Html::escape((string) ($context['managerEmail'] ?? ''));
  $details        = nl2br(Html::escape(trim((string) ($context['details'] ?? ''))));

  $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';

  switch ($key) {

    case 'booking_created_admin':
      $message['subject'] = t('New booking request #@id for @room', ['@id' => $booking_id, '@room' => $room_name]);
      $rows = [
        ['Booking ID', "#{$booking_id}"],
        ['Guest', $guest_email],
        ['Room', $room_name],
        ['Check-in', $check_in],
        ['Check-out', $check_out],
      ];
      if ($address !== '') $rows[] = ['Address', $address];
      $message['body'][] = hous_z_api_render_email(
        heading: 'New booking request',
        intro: 'A new booking is pending your review.',
        rows: $rows,
        details: $details,
        status: 'pending',
        status_label: 'Pending',
      );
      break;

    case 'booking_created_guest':
      $message['subject'] = t('Booking request received for @room', ['@room' => $room_name]);
      $rows = [
        ['Booking ID', "#{$booking_id}"],
        ['Room', $room_name],
        ['Check-in', $check_in],
        ['Check-out', $check_out],
        ['Status', 'Pending review'],
      ];
      if ($address !== '') $rows[] = ['Address', $address];
      $message['body'][] = hous_z_api_render_email(
        heading: 'Booking request received',
        intro: 'Your booking request was received. You will be notified once it is reviewed.',
        rows: $rows,
        details: $details,
        status: 'pending',
        status_label: 'Pending',
        cta_email: $manager_email,
      );
      break;

    case 'booking_confirmed':
      $message['subject'] = t('Booking confirmed: @room', ['@room' => $room_name]);
      $rows = [
        ['Booking ID', "#{$booking_id}"],
        ['Room', $room_name],
        ['Check-in', $check_in],
        ['Check-out', $check_out],
        ['Status', 'Confirmed'],
      ];
      if ($address !== '') $rows[] = ['Address', $address];
      $message['body'][] = hous_z_api_render_email(
        heading: 'Your booking is confirmed',
        intro: 'Great news — your booking has been approved.',
        rows: $rows,
        status: 'confirmed',
        status_label: 'Confirmed',
        cta_email: $manager_email,
      );
      break;

    case 'booking_cancelled':
      $message['subject'] = t('Booking cancelled: @room', ['@room' => $room_name]);
      $rows = [
        ['Booking ID', "#{$booking_id}"],
        ['Room', $room_name],
        ['Check-in', $check_in],
        ['Check-out', $check_out],
        ['Status', 'Cancelled'],
      ];
      $message['body'][] = hous_z_api_render_email(
        heading: 'Your booking has been cancelled',
        intro: 'Unfortunately your booking has been cancelled.',
        rows: $rows,
        details: $details,
        status: 'cancelled',
        status_label: 'Cancelled',
        cta_email: $manager_email,
      );
      break;

    case 'booking_status_admin':
      $message['subject'] = t('Booking #@id changed to @status', ['@id' => $booking_id, '@status' => $status_label]);
      $rows = [
        ['Booking ID', "#{$booking_id}"],
        ['Room', $room_name],
        ['Guest', $guest_email],
        ['Check-in', $check_in],
        ['Check-out', $check_out],
        ['New status', $status_label],
      ];
      if ($prev_status !== '') $rows[] = ['Previous', $prev_status];
      $message['body'][] = hous_z_api_render_email(
        heading: "Booking #{$booking_id} status updated",
        intro: 'A booking status has changed.',
        rows: $rows,
        details: $details,
        status: $status_machine,
        status_label: $status_label,
      );
      break;

    case 'booking_status_changed':
      $message['subject'] = t('Your booking status was updated: @room', ['@room' => $room_name]);
      $rows = [
        ['Booking ID', "#{$booking_id}"],
        ['Room', $room_name],
        ['Check-in', $check_in],
        ['Check-out', $check_out],
        ['New status', $status_label],
      ];
      if ($prev_status !== '') $rows[] = ['Previous', $prev_status];
      $message['body'][] = hous_z_api_render_email(
        heading: 'Your booking was updated',
        intro: 'Your booking status has changed.',
        rows: $rows,
        status: $status_machine,
        status_label: $status_label,
        cta_email: $manager_email,
      );
      break;
  }
}

/**
 * Renders a full branded Zoocha HTML email.
 */
function hous_z_api_render_email(
  string $heading,
  string $intro,
  array $rows = [],
  string $details = '',
  string $status = '',
  string $status_label = '',
  string $cta_email = '',
): string {
  // Badge colour per status.
  $badge_colours = [
    'confirmed' => ['bg' => '#ecfdf5', 'text' => '#10b981'],
    'cancelled' => ['bg' => '#fef2f2', 'text' => '#ef4444'],
    'pending'   => ['bg' => '#fff8e1', 'text' => '#f59e0b'],
  ];
  $badge = $badge_colours[$status] ?? ['bg' => '#f3f4f6', 'text' => '#6b7280'];

  // Build info rows.
  $rows_html = '';
  foreach ($rows as [$label, $value]) {
    if ($value === '') continue;
    $is_status = strtolower($label) === 'status' || strtolower($label) === 'new status';
    $cell = $is_status
      ? "<span style=\"display:inline-block;padding:3px 12px;border-radius:20px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;background:{$badge['bg']};color:{$badge['text']}\">{$value}</span>"
      : "<span style=\"font-size:14px;color:#1a1a2e;font-weight:500\">{$value}</span>";
    $rows_html .= "
      <tr>
        <td style=\"padding:10px 0;border-bottom:1px solid #ede9fe;font-size:12px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:0.5px;width:130px;vertical-align:top\">{$label}</td>
        <td style=\"padding:10px 0;border-bottom:1px solid #ede9fe;vertical-align:top\">{$cell}</td>
      </tr>";
  }

  $details_block = $details !== '' ? "
    <div style=\"margin-top:24px\">
      <p style=\"font-size:12px;font-weight:600;color:#9ca3af;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px\">Notes</p>
      <div style=\"background:#f9fafb;border-radius:6px;padding:16px 20px;font-size:14px;color:#374151;line-height:1.6\">{$details}</div>
    </div>" : '';

  $cta_block = $cta_email !== '' ? "
    <p style=\"margin-top:28px;font-size:14px;color:#6b7280;line-height:1.6\">
      Questions? Contact the manager at
      <a href=\"mailto:{$cta_email}\" style=\"color:#4B20D4;font-weight:600;text-decoration:none\">{$cta_email}</a>
    </p>" : '';

  // Logo: use images/logo.png from the module if present, otherwise fall back
  // to an inline SVG Z mark (purple bg, coral Z — Zoocha brand colours).
  // To use the real logo: place your PNG/SVG at
  //   web/modules/custom/hous_z_api/images/logo.png
  // and it will be picked up automatically.
  $module_path  = \Drupal::service('extension.list.module')->getPath('hous_z_api');
  $logo_file    = DRUPAL_ROOT . '/' . $module_path . '/images/logo.png';
  $has_logo_img = file_exists($logo_file);
  if ($has_logo_img) {
    $base_url = \Drupal::request()->getSchemeAndHttpHost();
    $logo_url = $base_url . '/' . $module_path . '/images/logo.png';
    // No wordmark text next to image — logo already contains the name.
    $logo_svg    = '<img src="' . $logo_url . '" height="40" alt="Zoocha" style="display:inline-block;vertical-align:middle">';
    $wordmark    = '';
    $footer_logo = '<img src="' . $logo_url . '" height="30" alt="Zoocha" style="display:inline-block;vertical-align:middle">';
  }
  else {
    // Inline SVG fallback: purple bg (#4B20D4), coral Z (#F04E37).
    $logo_svg    = '<svg width="36" height="36" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" style="display:inline-block;vertical-align:middle;margin-right:10px"><rect width="100" height="100" rx="16" fill="#4B20D4"/><polygon points="18,22 82,22 82,38 42,62 82,62 82,78 18,78 18,62 58,38 18,38" fill="#F04E37"/></svg>';
    $wordmark    = '<span style="color:#ffffff;font-size:20px;font-weight:700;letter-spacing:2px;text-transform:uppercase;vertical-align:middle">Zoocha</span>';
    // Footer variant: no purple rect (dark bg provides context), coral Z + white text.
    $footer_logo = '<svg width="28" height="28" viewBox="8 8 84 84" xmlns="http://www.w3.org/2000/svg" style="display:inline-block;vertical-align:middle;margin-right:8px"><polygon points="18,22 82,22 82,38 42,62 82,62 82,78 18,78 18,62 58,38 18,38" fill="#F04E37"/></svg>'
      . '<span style="color:#ffffff;font-size:15px;font-weight:700;letter-spacing:2px;text-transform:uppercase;vertical-align:middle">ZOOCHA</span>';
  }

  return <<<HTML
<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"></head>
<body style="margin:0;padding:0;background-color:#f4f4f7;font-family:Arial,Helvetica,sans-serif">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f7;padding:40px 0">
    <tr><td align="center">
      <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background:#ffffff;border-radius:8px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.08)">

        <!-- Header -->
        <tr>
          <td style="background:#4B20D4;padding:32px 40px">
            <div>{$logo_svg}{$wordmark}</div>
            <div style="width:36px;height:3px;background:#F04E37;border-radius:2px;margin-top:18px"></div>
          </td>
        </tr>

        <!-- Body -->
        <tr>
          <td style="padding:40px">
            <h1 style="font-size:22px;font-weight:700;color:#1a1a2e;margin:0 0 6px 0">{$heading}</h1>
            <p style="font-size:13px;color:#6b7280;margin:0 0 28px 0">Hous-Z · Room Booking System</p>
            <p style="font-size:15px;color:#374151;margin:0 0 24px 0;line-height:1.6">{$intro}</p>

            <!-- Info table -->
            <table width="100%" cellpadding="0" cellspacing="0" style="background:#f8f7ff;border-left:4px solid #4B20D4;border-radius:0 6px 6px 0;padding:4px 20px">
              <tr><td><table width="100%" cellpadding="0" cellspacing="0">{$rows_html}</table></td></tr>
            </table>

            {$details_block}
            {$cta_block}
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="background:#1a1a2e;padding:32px 40px">
            <div style="margin-bottom:14px">{$footer_logo}</div>
            <p style="color:#9ca3af;font-size:12px;margin:0 0 20px 0;line-height:1.8">
              Second Floor, Seed Warehouse, The Wash<br>
              Hertford, SG14 1PX &bull; 01992 256 700
            </p>
            <span style="display:inline-block;border:1px solid rgba(255,255,255,0.25);border-radius:50px;padding:5px 16px;color:#ffffff;font-size:11px;letter-spacing:0.3px">
              Powered by <strong>Drupal</strong>&trade;
            </span>
          </td>
        </tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
HTML;
}
