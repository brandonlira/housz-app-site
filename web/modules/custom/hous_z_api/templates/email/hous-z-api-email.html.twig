{#
/**
 * @file
 * Branded HTML email for Hous-Z booking notifications.
 *
 * Available variables:
 * - heading:      Main email heading.
 * - intro:        Introductory paragraph text.
 * - rows:         Array of booking detail rows. Each row has:
 *                   - label:     Column label (string).
 *                   - value:     Column value (string).
 *                   - is_status: TRUE when the value should render as a badge.
 * - details:      Optional notes/details text (plain, will be nl2br'd).
 * - status:       Booking status machine name (pending|confirmed|cancelled).
 * - status_label: Human-readable status label.
 * - cta_email:    Optional manager email for the contact CTA link.
 * - logo_url:     Absolute URL to logo.png, or empty string to use SVG mark.
 *
 * Override this template per email sub-type by creating:
 *   hous-z-api-email--{sub-type}.html.twig
 * e.g. hous-z-api-email--booking-confirmed.html.twig
 */
#}

{# ── Status badge colour map ── #}
{% set badge_map = {
  'confirmed': { 'bg': '#ecfdf5', 'text': '#059669' },
  'cancelled': { 'bg': '#fef2f2', 'text': '#dc2626' },
  'pending':   { 'bg': '#fff8e1', 'text': '#d97706' },
} %}
{% set badge = badge_map[status] is defined ? badge_map[status] : { 'bg': '#f3f4f6', 'text': '#6b7280' } %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ heading }}</title>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f7;font-family:Arial,Helvetica,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" role="presentation"
         style="background:#f4f4f7;padding:40px 0;">
    <tr>
      <td align="center">

        <table width="600" cellpadding="0" cellspacing="0" role="presentation"
               style="max-width:600px;width:100%;background:#ffffff;border-radius:8px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.08);">

          {# ── Header ── #}
          <tr>
            <td style="background:#4B20D4;padding:32px 40px;">
              {% if logo_url %}
                <img src="{{ logo_url }}" height="40" alt="Zoocha"
                     style="display:inline-block;vertical-align:middle;">
              {% else %}
                {# Inline SVG fallback — purple bg, coral Z #}
                <svg width="36" height="36" viewBox="0 0 100 100"
                     xmlns="http://www.w3.org/2000/svg"
                     style="display:inline-block;vertical-align:middle;margin-right:10px;">
                  <rect width="100" height="100" rx="16" fill="#4B20D4"/>
                  <polygon points="18,22 82,22 82,38 42,62 82,62 82,78 18,78 18,62 58,38 18,38"
                           fill="#F04E37"/>
                </svg>
                <span style="color:#ffffff;font-size:20px;font-weight:700;letter-spacing:2px;
                             text-transform:uppercase;vertical-align:middle;">Zoocha</span>
              {% endif %}
              <div style="width:36px;height:3px;background:#F04E37;border-radius:2px;margin-top:18px;"></div>
            </td>
          </tr>

          {# ── Body ── #}
          <tr>
            <td style="padding:40px;">

              <h1 style="font-size:22px;font-weight:700;color:#1a1a2e;margin:0 0 6px 0;">
                {{ heading }}
              </h1>
              <p style="font-size:13px;color:#6b7280;margin:0 0 28px 0;">
                Hous-Z &middot; Room Booking System
              </p>
              <p style="font-size:15px;color:#374151;margin:0 0 24px 0;line-height:1.6;">
                {{ intro }}
              </p>

              {# ── Info table ── #}
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation"
                     style="background:#f8f7ff;border-left:4px solid #4B20D4;
                            border-radius:0 6px 6px 0;padding:4px 20px;">
                <tr>
                  <td>
                    <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                      {% for row in rows %}
                        {% if row.value is not empty %}
                          <tr>
                            <td style="padding:10px 0;border-bottom:1px solid #ede9fe;
                                       font-size:12px;font-weight:600;color:#6b7280;
                                       text-transform:uppercase;letter-spacing:0.5px;
                                       width:130px;vertical-align:top;">
                              {{ row.label }}
                            </td>
                            <td style="padding:10px 0;border-bottom:1px solid #ede9fe;
                                       vertical-align:top;">
                              {% if row.is_status %}
                                <span style="display:inline-block;padding:3px 12px;
                                             border-radius:20px;font-size:12px;
                                             font-weight:700;text-transform:uppercase;
                                             letter-spacing:0.5px;
                                             background:{{ badge.bg }};color:{{ badge.text }};">
                                  {{ row.value }}
                                </span>
                              {% else %}
                                <span style="font-size:14px;color:#1a1a2e;font-weight:500;">
                                  {{ row.value }}
                                </span>
                              {% endif %}
                            </td>
                          </tr>
                        {% endif %}
                      {% endfor %}
                    </table>
                  </td>
                </tr>
              </table>

              {# ── Notes ── #}
              {% if details %}
                <div style="margin-top:24px;">
                  <p style="font-size:12px;font-weight:600;color:#9ca3af;
                             text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">
                    Notes
                  </p>
                  <div style="background:#f9fafb;border-radius:6px;padding:16px 20px;
                               font-size:14px;color:#374151;line-height:1.6;">
                    {{ details|nl2br }}
                  </div>
                </div>
              {% endif %}

              {# ── CTA ── #}
              {% if cta_email %}
                <p style="margin-top:28px;font-size:14px;color:#6b7280;line-height:1.6;">
                  Questions? Contact the manager at
                  <a href="mailto:{{ cta_email }}"
                     style="color:#4B20D4;font-weight:600;text-decoration:none;">
                    {{ cta_email }}
                  </a>
                </p>
              {% endif %}

            </td>
          </tr>

          {# ── Footer ── #}
          <tr>
            <td style="background:#1a1a2e;padding:32px 40px;">

              <div style="margin-bottom:14px;">
                {% if logo_url %}
                  <img src="{{ logo_url }}" height="30" alt="Zoocha"
                       style="display:inline-block;vertical-align:middle;">
                {% else %}
                  <svg width="28" height="28" viewBox="8 8 84 84"
                       xmlns="http://www.w3.org/2000/svg"
                       style="display:inline-block;vertical-align:middle;margin-right:8px;">
                    <polygon points="18,22 82,22 82,38 42,62 82,62 82,78 18,78 18,62 58,38 18,38"
                             fill="#F04E37"/>
                  </svg>
                  <span style="color:#ffffff;font-size:15px;font-weight:700;
                               letter-spacing:2px;text-transform:uppercase;
                               vertical-align:middle;">ZOOCHA</span>
                {% endif %}
              </div>

              <p style="color:#9ca3af;font-size:12px;margin:0 0 20px 0;line-height:1.8;">
                Second Floor, Seed Warehouse, The Wash<br>
                Hertford, SG14 1PX &bull; 01992 256 700
              </p>

              <span style="display:inline-block;border:1px solid rgba(255,255,255,0.25);
                           border-radius:50px;padding:5px 16px;color:#ffffff;
                           font-size:11px;letter-spacing:0.3px;">
                Powered by <strong>Drupal</strong>&trade;
              </span>

            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>
