/**
 * Implements hook_help().
 */
function beehotel_happening_today_help($route_name, \Drupal\Core\Routing\RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.beehotel_happening_today':
      return '<p>' . t('Generates daily reports and emails for hotel arrivals, departures, and daily tasks.') . '</p>';
  }
}

