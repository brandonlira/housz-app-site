<section class="daily-report__section daily-report__section--departures">
  <h2 class="daily-report__section-title">
    <span class="icon" aria-hidden="true">📤</span>
    {{ "Departures"|t }}
    <span class="badge" aria-label="{{ "Number of departures"|t }}: {{ departures|length }}">
      {{ departures|length }}
    </span>
  </h2>

  {% if departures %}
    <div class="daily-report__grid" role="list" aria-label="{{ "Today's departures"|t }}">
      {% for departure in departures %}
        <div class="daily-report__card" role="listitem">
          <div class="daily-report__card-header">
            <h3 class="daily-report__room-name">{{ departure.unit_name }}</h3>
            <span class="daily-report__time">
              <span class="icon" aria-hidden="true">⏰</span>
              <span class="visually-hidden">{{ "Check-out time"|t }}:</span>
              {{ departure.check_out_time }}
            </span>
          </div>

          {% if departure.guest_name %}
            <div class="daily-report__guest-info">
              <strong>{{ departure.guest_name }}</strong>
            </div>
          {% endif %}

          <div class="daily-report__booking-info">
            <ul>
              <li>
                <span class="visually-hidden">{{ "Stay start date"|t }}:</span>
                {{ "From"|t }}: {{ departure.start_date|date('d/m/Y') }}
              </li>
              <li>
                <span class="visually-hidden">{{ "Stay end date"|t }}:</span>
                {{ "To"|t }}: {{ departure.end_date|date('d/m/Y') }}
              </li>
            </ul>

            <div class="daily-report__stay-duration">
              <span class="visually-hidden">{{ "Number of nights stayed"|t }}:</span>
              {{ "Nights"|t }}: {{ departure.nights_stayed }}
            </div>
          </div>

          <div class="daily-report__comments">
            <ul>
              <li>
                <a href="{{ departure.booking_link }}"
                   class=""
                   target="_blank"
                   rel="noopener noreferrer"
                   data-comments="{{ departure.comment_count }}"
                   aria-label="{{ "View order comments"|t }} ({{ departure.comment_count }} {{ "comments"|t }})">
                  {{ "Comments"|t }}
                  {% if departure.comment_count > 0 %}
                    <span class="visually-hidden">({{ departure.comment_count }})</span>
                  {% endif %}
                </a>
              </li>
            </ul>
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="daily-report__empty">
      <p>{{ "No departures today"|t }}</p>
    </div>
  {% endif %}
</section>
