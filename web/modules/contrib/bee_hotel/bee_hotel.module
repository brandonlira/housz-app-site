  // With book unit forn in place, we don't need this anymore.
  unset($local_actions['bee.node.add_reservation']);

}

/**
 * Gets weight of a given module.
 *
 * The weight of uninstalled modules cannot be changed.
 *
 * @param string $module
 *   The name of the module (without the .module extension).
 */
function bee_hotel_get_module_weight($module) {
  $extension_config = \Drupal::configFactory()->getEditable('core.extension');
  return $extension_config->get("module." . $module);
}


/**
 * Create custom image styles required by the bee_hotel module.
 *
 * This function creates the cover_image_teaser image style with
 * scale and crop effect (300x200, centered). This style is used
 * for teaser images throughout the hotel listings.
 *
 * @todo 11 march 2026
 * @todo Verify dimensions meet design requirements
 * @todo Test with various image aspect ratios
 * @todo Consider adding additional effects if needed
 */
function bee_hotel_create_styles() {

  // Alert message for testing
  \Drupal::messenger()->addWarning(t('TO BE TESTED: Image style creation in progress. Please verify cover_image_teaser after installation.'));

  // Log the operation for debugging
  \Drupal::logger('bee_hotel')->notice('Creating cover_image_teaser image style');

  // Create cover_image_teaser image style.
  $style = Drupal\image\Entity\ImageStyle::create([
    'name' => 'cover_image_teaser',
    'label' => 'Cover Image Teaser',
  ]);

  // Add effects (adjust parameters as needed).
  $style->addImageEffect([
    'id' => 'image_scale_and_crop',
    'data' => [
      'width' => 300,
      'height' => 200,
      'anchor' => 'center-center',
    ],
    'weight' => 0,
  ]);

  // Save the style.
  $style->save();

  // Ensure the styles directory exists (optional).
  $directory = \Drupal::config('system.file')->get('default_scheme') . '://styles';
  \Drupal::service('file_system')->prepareDirectory($directory, \Drupal\Core\File\FileSystemInterface::CREATE_DIRECTORY);

  // Confirmation message
  \Drupal::messenger()->addStatus(t('Cover image teaser style has been created. Please test thoroughly.'));
}



/**
 * BEE Hotels is heavier than BEE module.
 */
function bee_hotel_update_modules_weight() {

  $weight = [
    'bee' => bee_hotel_get_module_weight('bee'),
    'bee_hotel' => bee_hotel_get_module_weight('bee_hotel'),
  ];

  // Set bee_hotel to a weight 1 lighter,
  // so ours moves higher in execution order.
  module_set_weight('bee_hotel', $weight['bee'] - 1);
}

/**
 * Preprocess the Commerce Order.
 */
function bee_hotel_preprocess_commerce_order(&$variables) {

  $data = [];
  $data['markup'] = "<hr/><h4>Bee Hotel</h4>";

  /** @var Drupal\commerce_order\Entity\OrderInterface $order */
  $data['order'] = $variables['order_entity'];
  $data['payment_gateway'] = $data['order']->get('payment_gateway')->entity;
  $data['order_id'] = $data['order']->get('order_id')->value;
  $data['order_first_item'] = $data['order']->get('order_items')[0]->entity;

  if ($data['order_first_item']->hasField('field_booking')) {

    $data['order_first_item_booking'] = $data['order_first_item']->get('field_booking')->entity;
    $data['order_first_item_booking_event'] = $data['order_first_item_booking']->get('booking_event_reference')->entity;

    if (isset($data['order_first_item_booking_event'])) {
      $data['order_first_item_booking_event_id'] = $data['order_first_item_booking_event']->get('id')->value;
      $data['markup'] .= "<a href='/admin/bat/events/event/" . $data['order_first_item_booking_event_id'] . "/edit?/admin/commerce/orders/" . $data['order_id'] . "'>Event</a>";
    }
  }

  $variables['additional_order_fields']['beehotel'] = [
    '#title' => "BAT event",
    '#markup' => $data['markup'],
    '#weight' => 98,
  ];

}



function bee_hotel__mail_alter(&$message) {
  // Log the full message to the watchdog for debugging.
  \Drupal::logger('mymodule')->debug('<pre>@message</pre>', ['@message' => print_r($message, TRUE)]);

  // If your email key is being altered, restore it.
  if ($message['key'] == 'your_key') {
    // Remove any multipart headers added by other modules.
    unset($message['headers']['Content-Type']);
    $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
    // If the body was turned into an array or altered, set it back.
    $message['body'] = $your_original_html_string;
    // Optionally tell any multipart module to skip conversion.
    $message['params']['mimemail'] = FALSE;
    $message['params']['htmlmail'] = FALSE;


    dump ($message);
    exit;

    exit;

  }
}



