/**
 * Implements hook_mail().
 */
function bee_hotel_mail($key, &$message, $params) {
  switch ($key) {
    case 'guest_message':
      // Forza l'header a HTML
      $message['headers']['Content-Type'] = 'text/html; charset=UTF-8; format=flowed; delsp=yes';

      $message['from'] = \Drupal::config('system.site')->get('mail');
      $message['subject'] = $params['subject'];

      // Il body deve essere passato come Markup per non essere "sanificato" in testo semplice
      $message['body'][] = \Drupal\Core\Render\Markup::create($params['message']);

      // Gestione opzionale del CC (se il tuo mailer lo supporta)
      if (isset($params['cc_recipient'])) {
        $cc = is_array($params['cc_recipient']) ? implode(',', $params['cc_recipient']) : $params['cc_recipient'];
        $message['headers']['Cc'] = $cc;
      }

      // --- GESTIONE BCC (Copia Nascosta) ---
      if (isset($params['bcc_recipient'])) {
        $bcc = is_array($params['bcc_recipient']) ? implode(',', $params['bcc_recipient']) : $params['bcc_recipient'];
        $message['headers']['Bcc'] = $bcc;
      }

      break;
  }
}

