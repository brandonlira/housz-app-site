{#
/**
 * @file
 * Hous-Z password reset page — full-screen split layout.
 * Applies to: /user/password
 */
#}

{{ attach_library('hous_z_theme/login') }}

<div class="hz-login-wrap">

  {# ── Left: Brand panel ── #}
  <div class="hz-login__brand" role="complementary">

    <div class="hz-login__logo">
      {% if logo %}
        <img src="{{ logo }}" alt="{{ site_name }}" class="hz-login__logo-img">
      {% else %}
        <div class="hz-login__logo-fallback">
          <svg width="44" height="44" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
            <rect width="100" height="100" rx="16" fill="rgba(255,255,255,0.15)"/>
            <polygon points="18,22 82,22 82,38 42,62 82,62 82,78 18,78 18,62 58,38 18,38"
                     fill="#F04E37"/>
          </svg>
          <span>ZOOCHA</span>
        </div>
      {% endif %}
    </div>

    <h1 class="hz-login__headline">
      Book your<br><em>perfect room</em><br>at Zoocha HQ.
    </h1>

    <p class="hz-login__tagline">
      The internal room booking system for Zoocha teams —
      fast, simple, and always up to date.
    </p>

    <ul class="hz-login__features">
      <li>Check availability in real time</li>
      <li>Single or double bed options</li>
      <li>Instant email confirmations</li>
      <li>Manage your bookings anytime</li>
    </ul>

  </div>

  {# ── Right: Form panel ── #}
  <div class="hz-login__form-panel" role="main">
    <a id="main-content" tabindex="-1"></a>

    <div class="hz-login__form-header">
      <h1>{{ 'Reset your password'|t }}</h1>
      <p>{{ 'Enter your email address to receive a reset link.'|t }}</p>
    </div>

    {% if page.highlighted %}
      {{ page.highlighted }}
    {% endif %}

    {{ page.content }}

    <div class="hz-login__footer-note">
      Hous-Z &bull; Zoocha Room Booking System &bull; &copy; {{ "now"|date("Y") }} Zoocha
    </div>
  </div>

</div>
