{#
/**
 * @file
 * Hous-Z login page — full-screen split layout.
 * Applies to: /user/login
 */
#}

{# Attach login-specific library #}
{{ attach_library('hous_z_theme/login') }}

<div class="hz-login-wrap">

  {# ── Left: Brand panel ── #}
  <div class="hz-login__brand" role="complementary">

    {# Logo #}
    <div class="hz-login__logo">
      <img src="/themes/hous_z_theme/images/zoocha-logotype.svg" alt="Zoocha" class="hz-login__logotype">
    </div>

    <div class="hz-login__eyebrow">Manager Portal</div>

    <h1 class="hz-login__headline">
      Manage room<br><em>bookings</em><br>at Zoocha.
    </h1>

    <p class="hz-login__tagline">
      Review requests, approve stays, and keep track of all accommodation
      at the Bristol office — all from one place.
    </p>

    <ul class="hz-login__features">
      <li>One-click booking approvals</li>
      <li>Full visibility of upcoming check-ins</li>
      <li>Automatic email notifications</li>
      <li>Manage rooms and availability</li>
    </ul>

  </div>

  {# ── Right: Form panel ── #}
  <div class="hz-login__form-panel" role="main">
    {% if hz_back_link %}{{ hz_back_link }}{% else %}<a href="/" class="hz-login__back"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg> Back to home</a>{% endif %}
    <a id="main-content" tabindex="-1"></a>

    <div class="hz-login__form-header">
      <h1>{{ 'Welcome back'|t }}</h1>
      <p>{{ 'Sign in to access the management portal.'|t }}</p>
    </div>

    {% if page.highlighted %}
      {{ page.highlighted }}
    {% endif %}

    {{ page.content }}

    <div class="hz-login__footer-note">
      Hous-Z &bull; Zoocha Room Booking System &bull; &copy; {{ "now"|date("Y") }} Zoocha
    </div>
  </div>

</div>
